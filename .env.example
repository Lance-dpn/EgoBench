# Copy this file to .env and fill in private values locally.
# Do not commit real API keys.

# Service agent model, OpenAI-compatible endpoint.
SERVICE_MODEL_NAME=gpt-5.5
SERVICE_API_KEY=
SERVICE_API_BASE_URL=https://api.example.com/v1

# Simulated user model. If omitted in .env, the runner can reuse SERVICE_*.
USER_MODEL_NAME=
USER_API_KEY=
USER_API_BASE_URL=
USER_TEMPERATURE=0

# Optional correction model override. If omitted, correction reuses SERVICE_*.
CORRECTION_MODEL_NAME=
CORRECTION_API_KEY=
CORRECTION_API_BASE_URL=
CORRECTION_API_TYPE=responses
CORRECTION_REASONING_EFFORT=medium

# Runner defaults.
SERVICE_REASONING_EFFORT=low
VIDEO_MODE=local
VIDEO_LOCAL_PATH=./videos
